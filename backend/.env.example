APP_NAME=Grocery House Manager
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://grocery_user:grocery_password@localhost:5432/grocery_house
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=

# Stripe subscription payments. Create recurring monthly Prices in Stripe and paste the price IDs here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# New-user Basic offer: create a Stripe coupon for 65% off, repeating for 2 months,
# create a promotion code for that coupon, and paste the promo_... ID here.
STRIPE_PROMOTION_CODE_BASIC_NEW_USER=
NEW_USER_OFFER_DAYS=14

# Owner/admin access for /admin dashboard. Separate multiple emails with commas.
ADMIN_EMAILS=kp3813294@gmail.com

# Optional: enables live nearby grocery stores, ratings, addresses, and Google Maps links in Household Pro smart suggestions.
# Requires Google Maps Platform Places API (New) enabled.
GOOGLE_PLACES_API_KEY=

# Optional SMTP for forgot-password verification emails.
# Recommended production setting: configure these using your support email provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Grocery House Manager
SMTP_USE_TLS=true

# Gmail/Google Workspace SMTP for password reset emails
# Use a 16-digit Google App Password. Do not use your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=kartik_patel_98@grocery-house-manager.com
SMTP_PASSWORD=your_16_digit_google_app_password
# First test with SMTP_FROM_EMAIL equal to SMTP_USERNAME.
# After that works, use support@ only if it is configured as a Gmail send-as address/alias.
SMTP_FROM_EMAIL=kartik_patel_98@grocery-house-manager.com
SMTP_FROM_NAME=Grocery House Manager
SMTP_USE_TLS=true
# Keep true if Docker logs show: OSError [Errno 101] Network is unreachable
SMTP_FORCE_IPV4=true


# Recommended production email fix when Gmail SMTP 587/465 is blocked by server/hosting.
# Resend sends using HTTPS port 443 instead of SMTP.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key_here
# Verify grocery-house-manager.com in Resend first, then use support@.
# For first testing, you may use Resend's allowed onboarding sender if your Resend account permits it.
RESEND_FROM_EMAIL=support@grocery-house-manager.com
RESEND_FROM_NAME=Grocery House Manager

# Grocery market/product integrations
# Open Food Facts is free/open product data for barcode/name lookup. No key needed.
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=GroceryHouseManager/1.0 (support@grocery-house-manager.com)

# Optional Apify actor for Canadian grocery price comparison over HTTPS 443.
# Actor: sunny_eternity/canada-grocery-price-comparison
# Supported retailers: loblaws, superstore, nofrills, saveonfoods, pricesmart, tnt
APIFY_API_TOKEN=
APIFY_CANADA_PRICE_ACTOR_ID=sunny_eternity/canada-grocery-price-comparison
APIFY_PRICE_OUTPUT_MODE=comparison
APIFY_PRICE_CACHE_HOURS=12
APIFY_PRICE_TIMEOUT_SECONDS=90
MARKET_MAX_COMPARE_ITEMS=12

# Professional receipt scanning (optional but recommended for production receipt automation)
# Veryfi returns structured receipt JSON: vendor/store, dates, line items, discounts, tax, total, and raw text.
# Get these from Veryfi account settings > Keys. Never commit real secrets.
RECEIPT_OCR_PROVIDER=veryfi
RECEIPT_SCAN_REVIEW_REQUIRED=true
RECEIPT_UPLOAD_MAX_MB=20
VERYFI_CLIENT_ID=
VERYFI_USERNAME=
VERYFI_API_KEY=
VERYFI_API_URL=https://api.veryfi.com/api/v8/partner/documents
VERYFI_TIMEOUT_SECONDS=60
