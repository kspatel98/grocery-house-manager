APP_NAME=Grocery House Manager
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://grocery_user:grocery_password@localhost:5432/grocery_house
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=

# Stripe subscription payments. Create recurring monthly Prices in Stripe and paste the price IDs here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# New-user Basic offer: create a Stripe coupon for 65% off, repeating for 2 months,
# create a promotion code for that coupon, and paste the promo_... ID here.
STRIPE_PROMOTION_CODE_BASIC_NEW_USER=
NEW_USER_OFFER_DAYS=14

# Owner/admin access for /admin dashboard. Separate multiple emails with commas.
ADMIN_EMAILS=kp3813294@gmail.com

# Optional: enables live nearby grocery stores, ratings, addresses, and Google Maps links in Household Pro smart suggestions.
# Requires Google Maps Platform Places API (New) enabled.
GOOGLE_PLACES_API_KEY=

# Optional SMTP for forgot-password verification emails.
# Recommended production setting: configure these using your support email provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Grocery House Manager
SMTP_USE_TLS=true
