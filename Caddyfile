# Redirect www to the main domain so login/localStorage does not split between two websites.
www.grocery-house-manager.com {
    redir https://grocery-house-manager.com{uri} permanent
}

grocery-house-manager.com {
    handle_path /api/* {
        reverse_proxy backend:8000
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:5173
    }
}
